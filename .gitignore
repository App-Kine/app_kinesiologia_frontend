# =============================================================================
# Auris · Frontend — .gitignore
# =============================================================================
# Ionic + Angular 20 + Capacitor
# Ref: http://git-scm.com/docs/gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Dependencias
# ---------------------------------------------------------------------------
/node_modules
jspm_packages/

# Lock files (la convención del equipo es no versionar package-lock.json)
package-lock.json
yarn.lock

# ---------------------------------------------------------------------------
# Builds y outputs
# ---------------------------------------------------------------------------
/dist
/www
/out-tsc
/bazel-out
/tmp

# ---------------------------------------------------------------------------
# Angular CLI
# ---------------------------------------------------------------------------
/.angular
/.angular/cache
.angular-cache/

# Carpetas basura que se crean en Linux/Mac si Windows leakea paths absolutos
# (eg "C:" como carpeta literal en lugar de la unidad).
/C:/

# ---------------------------------------------------------------------------
# Ionic / Capacitor / Cordova
# ---------------------------------------------------------------------------
/.ionic
/.versions
/platforms
/plugins
/android
/ios
.capacitor/

# ---------------------------------------------------------------------------
# Variables de entorno locales (si las agregas)
# ---------------------------------------------------------------------------
/src/environments/environment.local.ts
.env
.env.local
.env.*.local

# ---------------------------------------------------------------------------
# Tests y cobertura
# ---------------------------------------------------------------------------
/coverage
/karma-coverage
testem.log
.nyc_output/

# ---------------------------------------------------------------------------
# Sourcemaps y cachés
# ---------------------------------------------------------------------------
/.sourcemaps
.sass-cache/
/.nx
/.nx/cache
/connect.lock
/libpeerconnection.log
/typings

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
log.txt

# ---------------------------------------------------------------------------
# Archivos del sistema operativo
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
UserInterfaceState.xcuserstate

# ---------------------------------------------------------------------------
# Editores e IDEs
# ---------------------------------------------------------------------------
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-project
*.sublime-workspace

# Visual Studio Code (ignora todo excepto configs compartibles)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# Vim / Emacs
*.swp
*.swo
*.swn
*~
*.sw[mnpcod]

# ---------------------------------------------------------------------------
# Temporales
# ---------------------------------------------------------------------------
.tmp
*.tmp
*.tmp.*
